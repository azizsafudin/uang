# apps/api — all optional in dev; these are the built-in defaults.
DATABASE_URL=file:./data/uang.db
BETTER_AUTH_SECRET=change-me-in-production
WEB_ORIGIN=http://localhost:5173

# apps/web
# VITE_API_URL is NOT needed in dev: the Vite dev server proxies /api to the API
# (see vite.config.ts), so the app uses its own origin — same as production. Set
# it only to bypass the proxy and call the API cross-origin directly.
# VITE_API_URL=http://localhost:3000
